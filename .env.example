# Generate a secure JWT secret with: openssl rand -base64 32
JWT_SECRET=very-important-secret-dont-share-thanks

# Strong admin password — must be at least 12 characters
DEFAULT_ADMIN_PASSWORD=very-important-password-dont-share-thanks

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# Environment Type "production" or "development"
NODE_ENV=production

# Prevents startup if ALLOWED_ORIGINS or AZURE_REDIRECT_URI use HTTP in production.
# Also enables the HSTS header. Requires HTTPS on reverse proxy.
# Set to false only for local development or when HTTPS is handled at a different layer.
DEFAULT_SECURITY_POLICY=true

# Port for Application to be Served From
APPLICATION_PORT=8900

# Graph API permissions required (Delegated, under "API permissions"):
#   - User.Read   (to read displayName and mobilePhone of the signed-in user)
# Field mapping (in backend/routes/auth.js, lines ~148-149):
#   graphFullName = profileRes.body.displayName
#   graphPhone    = profileRes.body.mobilePhone
# Update those two lines and the $select query on the line above them.
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=https://yourdomain.com/api/auth/microsoft/callback